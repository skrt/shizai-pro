<%# locals: (purchase_orders:) %>
<div class="overflow-hidden rounded-md border border-gray-200">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="w-10 px-3 py-2">
          <input type="checkbox" class="h-4 w-4 rounded border-gray-300">
        </th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600"></th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">発注書番号</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">入荷予定コード</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">件名</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">ステータス</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">発注日</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">仕入先</th>
        <th class="whitespace-nowrap px-3 py-2 text-left text-xs font-medium text-gray-600">納品先</th>
        <th class="whitespace-nowrap px-3 py-2 text-right text-xs font-medium text-gray-600">合計金額</th>
        <th class="w-8 px-1 py-2"></th>
        <th class="w-20 px-3 py-2"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% purchase_orders.each do |po| %>
        <tr class="hover:bg-gray-50">
          <td class="px-3 py-2.5">
            <input type="checkbox" class="h-4 w-4 rounded border-gray-300">
          </td>
          <td class="px-3 py-2.5">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm text-gray-900"><%= po.order_number %></td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm">
            <% if po.arrival_code.present? %>
              <%= link_to po.arrival_code, "#", class: "text-blue-500 hover:underline" %>
            <% else %>
              <span class="text-gray-500">-</span>
            <% end %>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm">
            <% if po.subject.present? %>
              <span class="text-gray-900"><%= po.subject %></span>
            <% else %>
              <span class="text-gray-500">-</span>
            <% end %>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5">
            <span class="inline-flex items-center rounded-sm px-2 py-0.5 text-xs font-medium <%= po.status_badge_classes %>">
              <%= po.status_label %>
            </span>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm text-gray-900"><%= po.formatted_order_date %></td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm">
            <%= link_to po.supplier.name, "#", class: "text-blue-500 hover:underline" %>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5 text-sm">
            <%= link_to po.delivery_destination.name, "#", class: "text-blue-500 hover:underline" %>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5 text-right text-sm text-gray-900"><%= po.formatted_total_amount %></td>
          <td class="px-1 py-2.5 text-center">
            <div class="relative inline-block">
              <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              <% if po.message_count > 0 %>
                <span class="absolute -right-1 -top-1 h-2 w-2 rounded-full bg-red-500"></span>
              <% end %>
            </div>
          </td>
          <td class="whitespace-nowrap px-3 py-2.5">
            <%= link_to "詳細", "#", class: "inline-flex items-center justify-center rounded-md bg-blue-100 px-2 py-1 text-xs font-medium text-blue-700 hover:bg-blue-200" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
