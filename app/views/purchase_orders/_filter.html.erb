<%# locals: (suppliers:, delivery_destinations:) %>
<%# Component Catalog: input.html, select.html, combobox.html, datepicker.html — sm size (h-8) %>
<div class="relative z-20 mb-4 flex flex-col gap-3">
  <div class="flex items-center gap-2">
    <h3 class="text-sm font-medium text-gray-900">フィルター</h3>
    <%# Reset: xs/tertiary button %>
    <%= link_to "リセット", purchase_orders_path, class: "inline-flex items-center justify-center rounded-md border border-gray-200 bg-white px-2 py-1 text-xs font-medium text-btn-text-tertiary hover:bg-btn-tertiary-hover active:bg-btn-tertiary-active transition-colors" %>
  </div>

  <div class="flex items-end gap-3">
    <%# 発注書番号 — Input sm (h-8), fixed width %>
    <div class="w-[120px] shrink-0">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">発注書番号</label>
      <div class="flex items-center h-8 px-3 py-1.5 rounded-md border border-gray-200 bg-white focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
        <input type="text" class="flex-1 text-sm text-gray-900 placeholder-gray-400 outline-none bg-transparent" placeholder="">
      </div>
    </div>

    <%# 件名 — Input sm (h-8), flexible width %>
    <div class="flex-1 min-w-[120px]">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">件名</label>
      <div class="flex items-center h-8 px-3 py-1.5 rounded-md border border-gray-200 bg-white focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
        <input type="text" class="flex-1 text-sm text-gray-900 placeholder-gray-400 outline-none bg-transparent" placeholder="">
      </div>
    </div>

    <%# アイテム — ComboBox sm (h-8), flexible width %>
    <div class="flex-1 min-w-[120px]" data-controller="combobox">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">アイテム</label>
      <div class="relative">
        <div class="flex items-center h-8 px-3 py-1.5 rounded-md border border-gray-200 bg-white focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
          <input type="text"
                 data-combobox-target="input"
                 data-action="focus->combobox#show input->combobox#filter"
                 placeholder="すべて"
                 autocomplete="off"
                 class="flex-1 text-sm text-gray-900 placeholder-gray-400 outline-none bg-transparent">
          <button type="button" data-combobox-target="clear" data-action="combobox#clear" class="hidden items-center">
            <svg class="h-3 w-3 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div data-combobox-target="dropdown" class="absolute left-0 top-full z-30 mt-1 hidden w-full overflow-hidden rounded-md border border-gray-200 bg-white py-2 shadow-sm">
          <div data-combobox-target="count" class="px-3 py-2 text-xs text-gray-500">検索結果：1件</div>
          <div data-combobox-target="option" data-action="click->combobox#select" data-value="" data-label="" class="cursor-pointer px-3 py-2 text-sm text-gray-900 hover:bg-gray-50">すべて</div>
        </div>
      </div>
    </div>

    <%# 仕入先 — ComboBox sm (h-8), flexible width %>
    <div class="flex-1 min-w-[100px]" data-controller="combobox">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">仕入先</label>
      <div class="relative">
        <div class="flex items-center h-8 px-3 py-1.5 rounded-md border border-gray-200 bg-white focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
          <input type="text"
                 data-combobox-target="input"
                 data-action="focus->combobox#show input->combobox#filter"
                 placeholder="すべて"
                 autocomplete="off"
                 class="flex-1 text-sm text-gray-900 placeholder-gray-400 outline-none bg-transparent">
          <button type="button" data-combobox-target="clear" data-action="combobox#clear" class="hidden items-center">
            <svg class="h-3 w-3 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div data-combobox-target="dropdown" class="absolute left-0 top-full z-30 mt-1 hidden w-full overflow-hidden rounded-md border border-gray-200 bg-white py-2 shadow-sm">
          <div data-combobox-target="count" class="px-3 py-2 text-xs text-gray-500">検索結果：<%= suppliers.size %>件</div>
          <% suppliers.each do |s| %>
            <div data-combobox-target="option" data-action="click->combobox#select" data-value="<%= s.id %>" data-label="<%= s.name %>" class="cursor-pointer px-3 py-2 text-sm text-gray-900 hover:bg-gray-50"><%= s.name %></div>
          <% end %>
        </div>
      </div>
    </div>

    <%# 納品先 — Select sm (h-8), flexible width %>
    <div class="flex-1 min-w-[100px]">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">納品先</label>
      <div class="relative">
        <select class="flex items-center w-full h-8 appearance-none px-3 py-1.5 pr-8 rounded-md border border-gray-200 bg-white text-sm text-gray-900 outline-none cursor-pointer focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
          <option value="">すべて</option>
          <% delivery_destinations.each do |d| %>
            <option value="<%= d.id %>"><%= d.name %></option>
          <% end %>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
          <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
      </div>
    </div>

    <%# 発注日 — Date Range Picker sm (h-8) with Calendar (Component Catalog: datepicker.html) %>
    <div class="w-[240px] shrink-0" data-controller="daterange">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">発注日</label>
      <div class="relative">
        <div data-daterange-target="trigger"
             data-action="click->daterange#toggle"
             class="flex items-center gap-1.5 h-8 px-3 rounded-md border border-gray-200 bg-white cursor-pointer transition-colors hover:border-gray-300">
          <svg class="w-3 h-3 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M16 2v4M8 2v4M3 10h18"/></svg>
          <span data-daterange-target="display" class="flex-1 text-sm text-gray-400 whitespace-nowrap overflow-hidden text-ellipsis">yyyy/mm/dd - yyyy/mm/dd</span>
          <button type="button" data-daterange-target="clear" data-action="click->daterange#clear" class="hidden shrink-0">
            <svg class="w-3 h-3 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <%# Calendar Dropdown — 288px, rounded-lg, p-3, shadow-md %>
        <div data-daterange-target="dropdown" class="absolute top-full left-0 mt-1 z-50 hidden border border-gray-200 rounded-lg p-3 bg-white shadow-md" style="width:288px">
          <div class="flex items-center justify-between pb-2 h-11">
            <button type="button" data-action="click->daterange#prevMonth" class="text-gray-600 text-xl leading-none px-1 hover:text-gray-900 transition-colors">&lsaquo;</button>
            <span data-daterange-target="monthLabel" class="text-sm font-bold text-gray-900"></span>
            <button type="button" data-action="click->daterange#nextMonth" class="text-gray-600 text-xl leading-none px-1 hover:text-gray-900 transition-colors">&rsaquo;</button>
          </div>
          <div class="grid grid-cols-7 gap-0.5">
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">月</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">火</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">水</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">木</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">金</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">土</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">日</div>
          </div>
          <div data-daterange-target="weekGrid" class="grid grid-cols-7 gap-0.5"></div>
        </div>
      </div>
    </div>

    <%# 希望納品日 — Date Range Picker sm (h-8) with Calendar (Component Catalog: datepicker.html) %>
    <div class="w-[240px] shrink-0" data-controller="daterange">
      <label class="mb-1.5 block text-sm font-medium text-gray-900">希望納品日</label>
      <div class="relative">
        <div data-daterange-target="trigger"
             data-action="click->daterange#toggle"
             class="flex items-center gap-1.5 h-8 px-3 rounded-md border border-gray-200 bg-white cursor-pointer transition-colors hover:border-gray-300">
          <svg class="w-3 h-3 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M16 2v4M8 2v4M3 10h18"/></svg>
          <span data-daterange-target="display" class="flex-1 text-sm text-gray-400 whitespace-nowrap overflow-hidden text-ellipsis">yyyy/mm/dd - yyyy/mm/dd</span>
          <button type="button" data-daterange-target="clear" data-action="click->daterange#clear" class="hidden shrink-0">
            <svg class="w-3 h-3 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <%# Calendar Dropdown %>
        <div data-daterange-target="dropdown" class="absolute top-full right-0 mt-1 z-50 hidden border border-gray-200 rounded-lg p-3 bg-white shadow-md" style="width:288px">
          <div class="flex items-center justify-between pb-2 h-11">
            <button type="button" data-action="click->daterange#prevMonth" class="text-gray-600 text-xl leading-none px-1 hover:text-gray-900 transition-colors">&lsaquo;</button>
            <span data-daterange-target="monthLabel" class="text-sm font-bold text-gray-900"></span>
            <button type="button" data-action="click->daterange#nextMonth" class="text-gray-600 text-xl leading-none px-1 hover:text-gray-900 transition-colors">&rsaquo;</button>
          </div>
          <div class="grid grid-cols-7 gap-0.5">
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">月</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">火</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">水</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">木</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">金</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">土</div>
            <div class="h-9 flex items-center justify-center text-xs text-gray-400">日</div>
          </div>
          <div data-daterange-target="weekGrid" class="grid grid-cols-7 gap-0.5"></div>
        </div>
      </div>
    </div>
  </div>
</div>
