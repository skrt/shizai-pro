<%# locals: (page:, total_pages:, status_filter:) %>
<%# Component Catalog: pagination.html — テーブル外配置 %>
<% if total_pages > 1 %>
  <div class="flex items-center justify-end px-4 py-2">
    <div class="flex items-center gap-2">
      <%# Previous arrow — 32x32 (w-8 h-8), border gray-200, rounded-md %>
      <% if page > 1 %>
        <%= link_to purchase_orders_path(page: page - 1, status: status_filter), class: "w-8 h-8 flex items-center justify-center bg-white border border-gray-200 rounded-md hover:bg-gray-50 transition-colors" do %>
          <svg class="w-3 h-3 text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <% end %>
      <% else %>
        <span class="w-8 h-8 flex items-center justify-center bg-gray-100 border border-gray-200 rounded-md text-gray-400">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </span>
      <% end %>

      <%# Page numbers — h-8 min-w-[32px] px-3 py-1.5, text-sm font-medium %>
      <% (1..[total_pages, 5].min).each do |p| %>
        <% if p == page %>
          <span class="h-8 min-w-[32px] px-3 py-1.5 bg-gray-100 border border-gray-200 rounded-md text-sm font-medium text-gray-900 leading-5 flex items-center justify-center"><%= p %></span>
        <% else %>
          <%= link_to p, purchase_orders_path(page: p, status: status_filter), class: "h-8 min-w-[32px] px-3 py-1.5 bg-white border border-gray-200 rounded-md text-sm font-medium text-gray-900 leading-5 hover:bg-gray-50 flex items-center justify-center transition-colors" %>
        <% end %>
      <% end %>

      <%# Next arrow %>
      <% if page < total_pages %>
        <%= link_to purchase_orders_path(page: page + 1, status: status_filter), class: "w-8 h-8 flex items-center justify-center bg-white border border-gray-200 rounded-md hover:bg-gray-50 transition-colors" do %>
          <svg class="w-3 h-3 text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <% end %>
      <% else %>
        <span class="w-8 h-8 flex items-center justify-center bg-gray-100 border border-gray-200 rounded-md text-gray-400">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      <% end %>
    </div>
  </div>
<% end %>
