<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "shizai" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-screen flex-col bg-white font-sans text-gray-900 antialiased">
    <%# Header (Component Catalog: header.html) %>
    <header class="flex items-center justify-between px-6 h-16 bg-white">
      <%# Left: shizai logo SVG %>
      <svg width="80" height="25" viewBox="0 0 80 25" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M25.248 7.63763C23.0338 7.63763 21.1324 8.50844 19.8616 9.92217V0.402924H16.457V24.5968H19.8616V15.7327C19.8616 12.7992 21.7416 10.6897 24.3167 10.6897C26.834 10.6897 28.1103 12.3221 28.1103 15.3203V24.5968H31.5149V14.619C31.5149 10.3535 29.1114 7.63763 25.2469 7.63763H25.248Z" fill="#0F1424"/>
        <path d="M6.7617 24.9998C10.7978 24.9998 13.4797 22.9145 13.4797 19.699C13.4797 15.617 10.0794 15.0779 7.27993 14.6091C5.28283 14.2808 3.59268 13.9921 3.59268 12.5305C3.59268 11.3228 4.75694 10.5221 6.63901 10.5221C8.63972 10.5221 9.83934 11.3667 9.90494 12.9422H13.1298C13.0642 9.73132 10.5706 7.63734 6.71846 7.63734C2.86635 7.63734 0.2982 9.67 0.2982 12.6403C0.2982 16.4772 3.54965 17.104 6.30992 17.5767C8.33747 17.9182 10.115 18.2773 10.115 19.848C10.115 21.2311 8.70958 22.0054 6.88034 22.0054C4.88389 22.0054 3.4129 21.0908 3.32536 19.34H0C0.0873301 22.7742 2.73428 24.9998 6.7617 24.9998V24.9998Z" fill="#0F1424"/>
        <path d="M38.4612 8.0401H35.0566V24.596H38.4612V8.0401Z" fill="#0F1424"/>
        <path d="M36.7563 3.61948C37.7562 3.61948 38.5668 2.80923 38.5668 1.80974C38.5668 0.810249 37.7562 0 36.7563 0C35.7564 0 34.9458 0.810249 34.9458 1.80974C34.9458 2.80923 35.7564 3.61948 36.7563 3.61948Z" fill="#0F1424"/>
        <path d="M78.1894 3.61948C79.1893 3.61948 79.9999 2.80923 79.9999 1.80974C79.9999 0.810249 79.1893 0 78.1894 0C77.1895 0 76.3789 0.810249 76.3789 1.80974C76.3789 2.80923 77.1895 3.61948 78.1894 3.61948Z" fill="#0F1424"/>
        <path d="M79.8929 8.0401H76.4883V24.596H79.8929V8.0401Z" fill="#0F1424"/>
        <path d="M46.434 21.4388L54.3881 8.553V8.0401H41.7412V11.1582H49.1478L41.123 24.1621V24.596H54.4102V21.4388H46.434V21.4388Z" fill="#0F1424"/>
        <path d="M70.3762 8.03166L69.9387 10.102C68.4352 8.55925 66.322 7.63734 63.8804 7.63734C58.9464 7.63734 55.2568 11.3343 55.2568 16.31C55.2568 21.2724 58.9464 25 63.8804 25C66.2941 25 68.3864 24.0915 69.8866 22.5743L70.2167 24.588H72.9644V8.03208L70.3762 8.03166V8.03166ZM64.1481 21.7418C61.026 21.7418 58.7228 19.409 58.7228 16.31C58.7228 13.2109 61.026 10.8781 64.1481 10.8781C67.2703 10.8781 69.5515 13.1892 69.5515 16.31C69.5515 19.4307 67.2703 21.7418 64.1481 21.7418Z" fill="#0F1424"/>
      </svg>
      <%# Right: Company + User button (Catalog: header.html — xs/tertiary) %>
      <div class="flex items-center gap-3">
        <span class="text-base text-btn-text-tertiary">株式会社shizai</span>
        <button class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-md border border-gray-200 bg-white text-btn-text-tertiary hover:bg-btn-tertiary-hover active:bg-btn-tertiary-active transition-colors">
          澤井 亮太
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <button class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-md border border-gray-200 bg-white text-btn-text-tertiary hover:bg-btn-tertiary-hover active:bg-btn-tertiary-active transition-colors">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
          ヘルプ
        </button>
      </div>
    </header>

    <%# Navigation Tabs (Component Catalog: tabs.html — Underline Tabs) %>
    <nav class="bg-white px-8">
      <div class="border-b border-slate-200">
        <div class="flex">
          <%= render "shared/nav_tab", label: "発注", path: purchase_orders_path, active: controller_name == "purchase_orders" %>
          <%= render "shared/nav_tab", label: "納品", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "原価計算", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "アイテム", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "仕入先", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "納品先", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "メンバー", path: "#", active: false %>
          <%= render "shared/nav_tab", label: "設定", path: "#", active: false %>
        </div>
      </div>
    </nav>

    <%# Main Content %>
    <main class="flex flex-col">
      <%= yield %>
    </main>
  </body>
</html>
