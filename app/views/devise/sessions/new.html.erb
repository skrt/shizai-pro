<%# Login — based on mockups/auth/password_login %>
<div class="flex flex-col gap-6 items-center">
  <h1 class="text-2xl font-bold text-gray-900 text-center">
    ログイン
  </h1>

  <% if alert.present? %>
    <div class="w-full flex items-start gap-3 rounded-md border bg-red-50 border-badge-red px-4 py-3">
      <div class="flex-shrink-0 mt-[3px]">
        <svg class="w-4 h-4 text-badge-red" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="text-sm font-semibold text-gray-900 leading-5"><%= alert %></p>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { novalidate: true, class: "w-full flex flex-col gap-6" }) do |f| %>
    <div class="w-full space-y-2">
      <label class="block text-sm font-normal text-gray-900">メールアドレス</label>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full h-10 px-4 py-2 text-base border border-gray-200 rounded-md placeholder-gray-400 text-gray-900 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
    </div>

    <div class="w-full space-y-2" data-controller="password-toggle">
      <label class="block text-sm font-normal text-gray-900">パスワード</label>
      <div class="relative">
        <%= f.password_field :password, autocomplete: "current-password", data: { password_toggle_target: "input" }, class: "w-full h-10 px-4 py-2 pr-10 text-base border border-gray-200 rounded-md placeholder-gray-400 text-gray-900 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
        <button type="button" data-action="password-toggle#toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500">
          <svg data-password-toggle-target="showIcon" class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
          <svg data-password-toggle-target="hideIcon" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/></svg>
        </button>
      </div>
    </div>

    <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-medium text-white rounded-md bg-btn-primary hover:bg-btn-primary-hover active:bg-btn-primary-active transition-colors">
      ログイン
    </button>
  <% end %>

  <a href="<%= new_registration_path(resource_name) %>" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium rounded-md border border-gray-200 bg-white text-btn-text-tertiary hover:bg-btn-tertiary-hover active:bg-btn-tertiary-active transition-colors">
    アカウントをお持ちでない方はこちら
  </a>
</div>
